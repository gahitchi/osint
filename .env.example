# Copy to .env to enable optional modules. None are required.

# Have I Been Pwned (paid, ~$4/mo). If unset, the breach module is skipped.
# HIBP_API_KEY=

# Per-host requests-per-second cap. Default 1.0. Lower = more polite.
# SPECTER_HOST_RPS=1.0

# Global concurrency cap across all modules. Default 20.
# SPECTER_MAX_CONCURRENCY=20

# Contact email surfaced in the User-Agent (recommended by some APIs).
# SPECTER_CONTACT_EMAIL=you@example.com

# Override the directory where JSON/CSV reports are written.
# SPECTER_REPORTS_DIR=./reports
